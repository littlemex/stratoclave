    <mxCell id="bedrock" value="Amazon Bedrock — Claude family&#10;converse / converseStream&#10;us-east-1 primary → us-west-2 failover" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#1E7E5A;strokeWidth=3;fontSize=19;fontColor=#14442F;fontStyle=1;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
