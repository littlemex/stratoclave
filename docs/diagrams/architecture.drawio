    <!-- ===== Footer ===== -->
    <mxCell id="footer" value="No Postgres, no Redis, no SaaS — all state in DynamoDB. Three API surfaces share one credit pipeline, InfraRouter, and audit log. Backend task role holds no iam:* / sts:AssumeRole." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#CDE9DC;strokeWidth=1;fontSize=18;fontColor=#14442F;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="40" y="1260" width="2120" height="70" as="geometry"/></mxCell>

    <!-- ============ EDGES (routed to avoid crossing nodes) ============ -->
