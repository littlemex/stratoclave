    <mxCell id="TAKEAWAY" value="Stratoclave never parses AWS credentials and never holds an IdP refresh token. If the backend is fully compromised, an attacker cannot pivot into the user&#39;s IAM Identity Center because no IdP refresh token exists to steal." style="rounded=1;whiteSpace=wrap;overflow=hidden;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
