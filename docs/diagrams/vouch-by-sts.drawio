    <!-- Step Boxes -->

    <!-- B1: CLI sign -->
    <mxCell id="B1" value="SigV4-sign locally&#xa;POST GetCallerIdentity&#xa;(no creds leave this box)" style="rounded=1;whiteSpace=wrap;overflow=hidden;fillColor=#FFFFFF;strokeColor=#1E7E5A;fontStyle=0;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="20" y="100" width="510" height="80" as="geometry" />
    </mxCell>

    <!-- B2: Backend validate -->
    <mxCell id="B2" value="Validate request shape:&#xa;- Action=GetCallerIdentity only&#xa;- method=POST&#xa;- X-Amz-Date ±5 min&#xa;- URL allowlist sts.*.amazonaws.com" style="rounded=1;whiteSpace=wrap;overflow=hidden;fillColor=#FFFFFF;strokeColor=#1E7E5A;fontStyle=0;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="570" y="250" width="510" height="100" as="geometry" />
    </mxCell>

