  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SWIM LANES (tall vertical strips)                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Client Lane -->
    <mxCell id="lane-client" value="Client" style="swimlane;startSize=40;fillColor=#E65100;strokeColor=#E65100;fontColor=#FFFFFF;fontStyle=1;fontSize=13;swimlaneLine=1;swimlaneHead=0;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;swimlaneFillColor=#FFF3E0;" vertex="1" parent="1">
      <mxGeometry x="10" y="10" width="360" height="1640" as="geometry"/>
