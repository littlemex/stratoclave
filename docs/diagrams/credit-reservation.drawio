    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TAKEAWAY BOX                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="takeaway" value="One pipeline (mvp/_pipeline.py) covers both inference routes. Conditional UpdateItem prevents N concurrent requests from racing past the&#xa;quota. Under-spend is refunded; over-spend is best-effort re-reserved and surfaced as a credit_overrun audit event. UsageLogs always reflect&#xa;the upstream-reported token counts (Bedrock or bedrock-mantle), never the reservation." style="rounded=1;whiteSpace=wrap;fillColor=#FFFDE7;strokeColor=#F57F17;fontSize=12;fontStyle=2;align=left;spacingLeft=10;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="10" y="1665" width="1980" height="110" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
