      <mxGeometry x="1550" y="522" width="180" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="ann-step6" value="⑥ Compute Diff" style="text;fontSize=10;fontStyle=1;fontColor=#0D47A1;align=left;" vertex="1" parent="1">
      <mxGeometry x="390" y="662" width="160" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="ann-step7" value="⑦ Reconcile Credits" style="text;fontSize=10;fontStyle=1;fontColor=#6A1B9A;align=left;" vertex="1" parent="1">
      <mxGeometry x="1160" y="782" width="180" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="ann-step8" value="⑧ Return Response" style="text;fontSize=10;fontStyle=1;fontColor=#0D47A1;align=left;" vertex="1" parent="1">
