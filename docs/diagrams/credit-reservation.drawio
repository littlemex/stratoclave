    <!-- Backend Lane -->
    <mxCell id="lane-backend" value="Backend" style="swimlane;startSize=40;fillColor=#0D47A1;strokeColor=#0D47A1;fontColor=#FFFFFF;fontStyle=1;fontSize=13;swimlaneLine=1;swimlaneHead=0;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;swimlaneFillColor=#E3F2FD;" vertex="1" parent="1">
      <mxGeometry x="380" y="10" width="760" height="1640" as="geometry"/>
    </mxCell>

    <!-- DynamoDB Lane -->
    <mxCell id="lane-dynamo" value="DynamoDB" style="swimlane;startSize=40;fillColor=#6A1B9A;strokeColor=#6A1B9A;fontColor=#FFFFFF;fontStyle=1;fontSize=13;swimlaneLine=1;swimlaneHead=0;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;swimlaneFillColor=#F3E5F5;" vertex="1" parent="1">
      <mxGeometry x="1150" y="10" width="380" height="1640" as="geometry"/>
    </mxCell>

    <!-- Upstream Lane -->
    <mxCell id="lane-upstream" value="Bedrock / bedrock-mantle" style="swimlane;startSize=40;fillColor=#2E7D32;strokeColor=#2E7D32;fontColor=#FFFFFF;fontStyle=1;fontSize=13;swimlaneLine=1;swimlaneHead=0;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;swimlaneFillColor=#E8F5E9;" vertex="1" parent="1">
      <mxGeometry x="1540" y="10" width="450" height="1640" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 1 — Client sends request                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step1-client" value="POST /v1/messages&#xa;(Anthropic: max_tokens)&#xa;&#xa;POST /openai/v1/responses&#xa;(OpenAI: max_output_tokens)" style="rounded=0;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="20" y="80" width="340" height="90" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Arrow: Client → Backend (Step 1)                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="edge-1-to-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#555555;" edge="1" source="box-step1-client" target="box-step2-backend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-1-to-2" value="request body" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="362" y="110" width="120" height="24" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 2 — Backend: Auth + Reservation                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step2-backend" value="Auth: Cognito JWT or sk-stratoclave-* API key&#xa;Scope: messages:send or responses:send&#xa;&#xa;Reservation R:&#xa;  Anthropic: R = max_tokens + chars_in_input//3, floor 1024&#xa;  OpenAI:    R = max_output_tokens × effort_multiplier + chars_in_input//3, floor 8192&#xa;             (effort_multiplier: low=1 / medium=2 / high=4 / xhigh=8)" style="rounded=0;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#0D47A1;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="390" y="60" width="740" height="140" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Arrow: Backend → DynamoDB (Step 3 — conditional UpdateItem)        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="edge-2-to-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6A1B9A;" edge="1" source="box-step2-backend" target="box-step3-dynamo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-2-to-3" value="conditional UpdateItem (+R)" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1140" y="150" width="200" height="24" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 3 — DynamoDB: Conditional UpdateItem                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step3-dynamo" value="UserTenants UpdateItem&#xa;SET credit_used = credit_used + :R&#xa;Condition: credit_used + :R &lt;= total_credit&#xa;&#xa;Fail → 402 Payment Required&#xa;(no upstream call)" style="rounded=0;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="1160" y="220" width="360" height="130" as="geometry"/>
    </mxCell>

    <!-- Arrow: DynamoDB → Backend (402 short-circuit) -->
    <mxCell id="edge-3-402" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.8;exitDx=0;exitDy=0;entryX=1;entryY=0.8;entryDx=0;entryDy=0;strokeColor=#C62828;dashed=1;" edge="1" source="box-step3-dynamo" target="box-step2-backend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-3-402" value="402 if condition fails" style="text;fontSize=10;background=#FFEBEE;opacity=90;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#C62828;" vertex="1" parent="1">
      <mxGeometry x="1140" y="320" width="160" height="24" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 4 — Backend: Upstream invocation box                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step4-backend" value="Invoke upstream:&#xa;  Anthropic → Bedrock converse/converseStream (us-east-1, boto3, IAM task role)&#xa;  OpenAI    → httpx POST bedrock-mantle.{us-west-2,us-east-2}.api.aws/openai/v1/responses&#xa;              bearer token via aws-bedrock-token-generator.provide_token (15-min TTL)" style="rounded=0;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#0D47A1;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="390" y="420" width="740" height="100" as="geometry"/>
    </mxCell>

    <!-- Arrow: Backend → Upstream (Step 4) -->
    <mxCell id="edge-4-to-upstream" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#2E7D32;" edge="1" source="box-step4-backend" target="box-step4-upstream" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-4-to-upstream" value="invoke (stream or sync)" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1540" y="450" width="170" height="24" as="geometry"/>
    </mxCell>

    <!-- STEP 4 — Upstream box -->
    <mxCell id="box-step4-upstream" value="Bedrock converse / converseStream&#xa;OR bedrock-mantle /openai/v1/responses" style="rounded=0;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="1550" y="420" width="430" height="70" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 5 — Upstream: Response                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step5-upstream" value="Anthropic: {input_tokens, output_tokens, stopReason}&#xa;OpenAI: {input_tokens, output_tokens&#xa;         incl. reasoning_tokens, stop signal}" style="rounded=0;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="1550" y="540" width="430" height="80" as="geometry"/>
    </mxCell>

    <!-- Arrow: Upstream response → Backend (Step 5) -->
    <mxCell id="edge-5-to-backend" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#2E7D32;" edge="1" source="box-step5-upstream" target="box-step6-backend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-5-to-backend" value="usage + response body" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1380" y="620" width="160" height="24" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 6 — Backend: Compute diff                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step6-backend" value="Compute diff = R − actual&#xa;where actual = input_tokens + output_tokens" style="rounded=0;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#0D47A1;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="390" y="680" width="740" height="60" as="geometry"/>
    </mxCell>

    <!-- Arrow: Backend → DynamoDB (Step 7) -->
    <mxCell id="edge-6-to-dynamo" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6A1B9A;" edge="1" source="box-step6-backend" target="box-step7-dynamo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-6-to-dynamo" value="refund or re-reserve + PutItem" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1140" y="730" width="200" height="24" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 7 — DynamoDB: Refund/overrun + UsageLogs                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step7-dynamo" value="If diff &gt;= 0:&#xa;  SET credit_used = credit_used - diff (refund)&#xa;If diff &lt; 0: best-effort re-reserve&#xa;  up to total_credit;&#xa;  log credit_overrun warning&#xa;&#xa;PutItem UsageLogs:&#xa;  model_id, input_tokens, output_tokens,&#xa;  actor, timestamp" style="rounded=0;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="1160" y="800" width="360" height="160" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 8 — Backend: Return response                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="box-step8-backend" value="Return upstream response body to Client&#xa;(Anthropic-shaped or OpenAI-Responses-shaped)" style="rounded=0;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#0D47A1;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="390" y="1000" width="740" height="60" as="geometry"/>
    </mxCell>

    <!-- Arrow: Backend → Client (Step 8) -->
    <mxCell id="edge-8-to-client" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#E65100;" edge="1" source="box-step8-backend" target="box-step8-client" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-edge-8-to-client" value="response body" style="text;fontSize=10;background=#FFFFFF;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="1025" width="120" height="24" as="geometry"/>
    </mxCell>

    <!-- STEP 8 — Client: Receive response -->
    <mxCell id="box-step8-client" value="Response received&#xa;(Anthropic or OpenAI shape)" style="rounded=0;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;align=left;spacingLeft=6;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="20" y="1000" width="340" height="60" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STEP SEQUENCE CONNECTORS (vertical flow within lanes)              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Backend step2 → step4 -->
    <mxCell id="edge-backend-2-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0D47A1;" edge="1" source="box-step2-backend" target="box-step4-backend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Backend step4 → step6 -->
    <mxCell id="edge-backend-4-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0D47A1;" edge="1" source="box-step4-backend" target="box-step6-backend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Backend step6 → step8 -->
    <mxCell id="edge-backend-6-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0D47A1;" edge="1" source="box-step6-backend" target="box-step8-backend" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="760" y="770"/>
          <mxPoint x="760" y="990"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Upstream step4 → step5 -->
    <mxCell id="edge-upstream-4-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#2E7D32;" edge="1" source="box-step4-upstream" target="box-step5-upstream" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- DynamoDB step3 → step7 (success path) -->
    <mxCell id="edge-dynamo-3-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#6A1B9A;dashed=1;" edge="1" source="box-step3-dynamo" target="box-step7-dynamo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="lbl-dynamo-3-7" value="success path" style="text;fontSize=10;background=#F3E5F5;opacity=80;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1270" y="650" width="110" height="24" as="geometry"/>
    </mxCell>

