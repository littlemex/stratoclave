# Stratoclave Backend Configuration

# ================================================================
# Server
# ================================================================
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development  # development, production, local

# ================================================================
# CORS
# ================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3003

# ================================================================
# Authentication
# ================================================================
# AUTH_MODE: none | apikey | shadow | oidc
# [WARNING] AUTH_MODE=none is refused at startup in production environments
AUTH_MODE=none

# OIDC Configuration (required when AUTH_MODE=oidc)
# OIDC_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXX
# OIDC_AUDIENCE=your-client-id

# Cognito Configuration (for user management via the Admin API)
# COGNITO_USER_POOL_ID=us-east-1_XXXXX

# Auth0 Configuration (not implemented - stub)
# AUTH0_DOMAIN=your-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret

# ================================================================
# Multi-Tenant
# ================================================================
TENANT_ISOLATION_ENABLED=false

# AWS Verified Permissions (recommended when TENANT_ISOLATION_ENABLED=true)
VERIFIED_PERMISSIONS_ENABLED=false
# VERIFIED_PERMISSIONS_POLICY_STORE_ID=ps-xxxxxxxx

# ================================================================
# Database (PostgreSQL)
# ================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stratoclave
POSTGRES_USER=stratoclave
POSTGRES_PASSWORD=your-password-here

# Redis (optional - for future session storage)
# REDIS_URL=redis://localhost:6379/0

# ================================================================
# AWS Bedrock Configuration
# ================================================================
# AWS_PROFILE=default
# AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-v2:0
# BEDROCK_ENDPOINT_URL=https://localhost:8443  # when routing through a Proxy Gateway
# BEDROCK_VERIFY_SSL=false  # only for local development behind a Proxy Gateway

# ================================================================
# OpenClaw Integration
# ================================================================
OPENCLAW_ENABLED=true
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_AUTH_TOKEN=your-openclaw-token-here
