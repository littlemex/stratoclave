{
  "version": "2026-06-02.1",
  "roles": {
    "admin": {
      "description": "Root: manages all tenants, users, SSO trusted accounts, and API keys.",
      "permissions": [
        "users:*",
        "tenants:*",
        "usage:*",
        "permissions:*",
        "accounts:*",
        "apikeys:*",
        "billing:*",
        "messages:send",
        "responses:send"
      ]
    },
    "team_lead": {
      "description": "Manages owned tenants, plus self usage history and self API keys.",
      "permissions": [
        "tenants:create",
        "tenants:read-own",
        "usage:read-own-tenant",
        "usage:read-self",
        "apikeys:read-self",
        "apikeys:create-self",
        "apikeys:revoke-self",
        "billing:read",
        "billing:write",
        "messages:send",
        "responses:send"
      ]
    },
    "user": {
      "description": "End user: invokes Messages and Responses APIs and manages own API keys.",
      "permissions": [
        "messages:send",
        "responses:send",
        "usage:read-self",
        "apikeys:read-self",
        "apikeys:create-self",
        "apikeys:revoke-self"
      ]
    }
  }
}
