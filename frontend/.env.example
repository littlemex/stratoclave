# Frontend environment variables (Vite)
#
# Copy this file to `.env.local` and adjust as needed. Vite automatically
# loads `.env.local` during `npm run dev` and `npm run build`.
#
# Do NOT commit `.env.local` — it is listed in .gitignore.

# Where the Vite dev server should proxy /api and /v1 requests.
# For local-only development, point this at a running Backend instance.
# For a deployed Stratoclave, use your CloudFront URL.
VITE_BACKEND_PROXY_TARGET=http://localhost:8000

# Uncomment to silence the "Cognito domain must start with https://" check
# in RuntimeConfig validation while iterating locally. Do NOT set in
# production.
# VITE_ALLOW_INSECURE_COGNITO_DOMAIN=1
