{
  "name": "iac",
  "version": "0.1.0",
  "bin": {
    "iac": "bin/iac.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "validate": "bash scripts/validate-config.sh",
    "validate:offline": "bash scripts/validate-config.sh --skip-aws",
    "predeploy": "npm run validate",
    "deploy": "cdk deploy",
    "deploy:full": "bash scripts/deploy-with-update.sh",
    "deploy:update-cognito": "bash scripts/deploy-with-update.sh --stage2-only",
    "lint": "eslint . --ext ts",
    "lint:fix": "eslint . --ext ts --fix",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --check \"**/*.{ts,json}\""
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "aws-cdk": "2.1000.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "cdk-nag": "^2.28.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.180.0",
    "constructs": "^10.0.0"
  }
}
