{
  "name": "iac",
  "version": "0.1.0",
  "bin": {
    "iac": "bin/iac.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "validate": "bash scripts/validate-config.sh",
    "validate:offline": "bash scripts/validate-config.sh --skip-aws",
    "predeploy": "npm run validate",
    "deploy": "cdk deploy",
    "deploy:full": "bash scripts/deploy-with-update.sh",
    "deploy:update-cognito": "bash scripts/deploy-with-update.sh --stage2-only",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --check \"**/*.{ts,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.59.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "aws-cdk": "2.1119.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "cdk-nag": "^2.38.1"
  },
  "dependencies": {
    "aws-cdk-lib": "2.251.0",
    "constructs": "^10.0.0"
  }
}
